{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task to be completed",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "priority", "completed", "createdAt"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "A scheduled meeting",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "date", "createdAt"]
    },
    "LogisticJob": {
      "title": "LogisticJob",
      "description": "A logistics order or job",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "delivered"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of user profiles"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Collection of tasks"
    },
    "/meetings/{meetingId}": {
      "schema": { "$ref": "#/entities/Meeting" },
      "description": "Collection of meetings"
    },
    "/logistics/{logisticId}": {
      "schema": { "$ref": "#/entities/LogisticJob" },
      "description": "Collection of logistics jobs"
    }
  }
}
